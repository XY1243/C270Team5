PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=25050347
DB_NAME=event_finder

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

UPLOAD_DIR=uploads/banners
MAX_UPLOAD_SIZE_MB=5

CORS_ORIGIN=*

# Google Calendar / OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google-calendar/callback
GOOGLE_CALENDAR_TIMEZONE=UTC

# Nodemailer SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-sending-email@gmail.com
SMTP_PASS=your-app-password-or-api-key
MAIL_FROM="EventFinder <noreply@eventfinder.local>"

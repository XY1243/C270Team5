<nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="#">Events</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="collapsibleNavbar">
        <ul class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" id="dashboardNavLink" href="/login">Dashboard</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/entry">Events</a>
          </li> 
          <li class="nav-item">
            <a class="nav-link" href="/history">History</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/map">Map</a>
          </li>
        </ul>
      </div>
      <script>
        (function() {
          const link = document.getElementById('dashboardNavLink');
          if (!link) return;
          try {
            const user = JSON.parse(localStorage.getItem('authUser') || 'null');
            if (user && user.role) {
              if (user.role === 'organiser') link.href = '/organiser/dashboard';
              else link.href = '/user/dashboard';
            } else {
              link.href = '/login?next=/';
            }
          } catch (err) {
            link.href = '/login?next=/';
          }
        })();
      </script>
    </div>
  </nav>
  
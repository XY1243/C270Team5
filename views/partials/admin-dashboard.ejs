
<!DOCTYPE html>
<html>
<head>
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="dashboard-container">
        <div class="dashboard-header">
            <h1>⚙️ <%= title %></h1>
            <div class="user-info">
                <span>Welcome, <strong><%= user %></strong></span>
                <span class="badge"><%= role %></span>
                <a href="/" class="logout-btn">Logout</a>
            </div>
        </div>
        
        <div class="dashboard-nav">
            <a href="/admin/dashboard" class="active">Dashboard</a>
            <a href="/admin/users">Manage Users</a>
            <a href="/admin/events">Manage Events</a>
        </div>
        
        <div class="dashboard-content">
            <h2>Overview</h2>
            <div class="card-grid">
                <div class="card">
                    <h3>Total Users</h3>
                    <div class="number"><%= stats.users %></div>
                </div>
                <div class="card">
                    <h3>Total Events</h3>
                    <div class="number"><%= stats.events %></div>
                </div>
                <div class="card" style="border-left-color: #f39c12;">
                    <h3>Pending Events</h3>
                    <div class="number" style="color: #f39c12;"><%= stats.pending %></div>
                </div>
            </div>
            
            <h2 style="margin-top: 30px;">Recent Users</h2>
            <% if (recentUsers && recentUsers.length > 0) { %>
                <div class="card-grid">
                    <% recentUsers.forEach(user => { %>
                        <div class="card">
                            <h3><%= user.name %></h3>
                            <p><%= user.email %></p>
                            <p><strong>Role:</strong> <span class="badge"><%= user.role %></span></p>
                            <p><strong>Status:</strong> <span class="badge"><%= user.status %></span></p>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <p>No users found.</p>
            <% } %>
            
            <h2 style="margin-top: 30px;">Recent Events</h2>
            <% if (recentEvents && recentEvents.length > 0) { %>
                <div class="card-grid">
                    <% recentEvents.forEach(event => { %>
                        <div class="card">
                            <h3><%= event.title %></h3>
                            <p><strong>Organiser:</strong> <%= event.organiser_name %></p>
                            <p><strong>Status:</strong> <span class="badge"><%= event.status %></span></p>
                            <p><strong>Date:</strong> <%= new Date(event.starts_at).toLocaleDateString() %></p>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <p>No events found.</p>
            <% } %>
        </div>
    </div>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Events Finder - Create Event</title>
    <link rel="stylesheet" href="/styles.css"> 
    <style>
        /* Custom form style fixes to replace missing Bootstrap styles */
        .form-layout-group {
            margin-bottom: 20px;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }
        .form-label-bold {
            font-weight: 600;
            color: #1f2937;
            font-size: 14px;
        }
        .form-control-custom {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-size: 14px;
            font-family: inherit;
            color: #333;
            box-sizing: border-box;
        }
        .form-control-custom:focus {
            outline: none;
            border-color: #090909;
        }
        /* Custom side-by-side split row for Date and Time alignment */
        .form-split-row {
            display: flex;
            gap: 16px;
            margin-bottom: 20px;
        }
        .form-split-col {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }
        /* Action buttons footer layout alignment */
        .form-actions-bar {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            margin-top: 24px;
        }
        .btn-custom-cancel {
            text-decoration: none;
            padding: 8px 20px;
            border-radius: 6px;
            background: #6c7280;
            color: white;
            font-size: 14px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
        }
        .btn-custom-cancel:hover {
            background: #5a606d;
        }
        .btn-custom-submit {
            padding: 8px 24px;
            border: none;
            border-radius: 6px;
            background: #090909;
            color: white;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
        }
        .btn-custom-submit:hover {
            background: #222;
        }
        .alert-warning-box {
            background-color: #fff3cd;
            color: #664d03;
            border: 1px solid #ffe69c;
            padding: 12px 16px;
            border-radius: 6px;
            font-size: 0.85rem;
            margin-bottom: 20px;
            line-height: 1.4;
        }
        .alert-danger-box {
            background-color: #f8d7da;
            color: #842029;
            border: 1px solid #f5c2c7;
            padding: 12px 16px;
            border-radius: 6px;
            font-size: 0.85rem;
            margin-bottom: 20px;
        }
        .d-hidden {
            display: none;
        }
    </style>
</head>
<body class="bg-light text-dark">

    <div class="dashboard-container">
        <div class="dashboard-header">
            <h1>📋 <%= title %></h1>
            <div class="user-info">
                <span>Welcome, <strong id="navUsername"><%= user %></strong></span>
                <span class="badge">organiser</span>
                <a href="/" class="logout-btn">Logout</a>
            </div>
        </div>

        <nav class="dashboard-nav bg-white">
            <a href="/organiser/dashboard">Dashboard</a>
            <a href="/organiser/events">My Events</a>
            <a href="/organiser/create-event" class="active">Create Event</a>
            <a href="/map">Map</a>
        </nav>

        <div class="dashboard-content">
            <div style="display: flex; justify-content: center; width: 100%;">
                <div class="w-100" style="max-width: 700px; width: 100%;">
                    <h2 class="mb-4 text-dark fw-bold text-start" style="margin-bottom: 20px;">Create New Event</h2>
                    
                    <form id="createEventForm" class="card" style="border-left: 5px solid #090909 !important; background: white; border-radius: 12px; padding: 25px; box-shadow: 0 5px 15px rgba(0,0,0,.06); width: 100%; box-sizing: border-box;">
                        
                        <div class="form-layout-group">
                            <label for="title" class="form-label-bold">Event Title:</label>
                            <input type="text" class="form-control-custom" id="title" placeholder="Enter title e.g., Tech Networking Mixer" name="title" required>
                        </div>

                        <div class="form-split-row">
                            <div class="form-split-col">
                                <label for="date" class="form-label-bold">Date:</label>
                                <input type="date" class="form-control-custom" id="date" name="date" required>
                            </div>

                            <div class="col-md-6 mb-3 form-split-col">
                                <label for="time" class="form-label-bold">Time:</label>
                                <input type="time" class="form-control-custom" id="time" name="time" required>
                            </div>
                        </div>

                        <div class="form-layout-group">
                            <label for="venue" class="form-label-bold">Venue Name:</label>
                            <input type="text" class="form-control-custom" id="venue" name="venue" placeholder="Enter venue name" required>
                        </div>

                        <input type="hidden" id="lat" value="1.290270">
                        <input type="hidden" id="lng" value="103.851959">
                        <input type="hidden" id="capacity" value="50">

                        <div class="form-layout-group">
                            <label for="type" class="form-label-bold">Event Type:</label>
                            <select id="type" name="type" class="form-control-custom" style="background-color: white;">
                                <option value="Community">Community</option>
                                <option value="Social/Party">Social/ Party</option>
                                <option value="Workshop">Workshop</option>
                                <option value="Arts">Arts</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>

                        <div class="form-layout-group">
                            <label for="descriptions" class="form-label-bold">Descriptions:</label>
                            <textarea class="form-control-custom" id="descriptions" rows="4" placeholder="Provide a brief summary of what attendees can expect during the event" name="descriptions" style="resize: vertical;" required></textarea>
                        </div>

                        <div class="alert-warning-box">
                            <strong>⚠️ Notice:</strong> Your event will be submitted as pending. It must be authorized by an administrator before appearing publicly.
                        </div>

                        <div id="formError" class="alert-danger-box d-hidden"></div>
                        
                        <div class="form-actions-bar">
                            <a id="cancelLink" href="/organiser/dashboard" class="btn-custom-cancel">Cancel</a>
                            <button type="submit" class="btn-custom-submit">Request</button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="/js/auth.js"></script>
    <script>
      const form = document.getElementById('createEventForm');
      const errorBox = document.getElementById('formError');
      const cancelLink = document.getElementById('cancelLink');
      const logoutBtn = document.getElementById('logoutBtn');
      
      const user = Auth.getUser();
      if (!user || (user.role !== 'organiser' && user.role !== 'admin')) {
        window.location.href = '/login?next=/';
      } else {
        document.getElementById('navUsername').textContent = user.name || 'Organiser';
      }

      if (cancelLink) {
        cancelLink.href = user.role === 'admin' ? '/admin/dashboard' : '/organiser/dashboard';
      }

      if (logoutBtn) {
        logoutBtn.addEventListener('click', (e) => {
            e.preventDefault();
            Auth.logout();
            window.location.href = '/login';
        });
      }

      function showError(message) {
        errorBox.textContent = message;
        errorBox.classList.remove('d-hidden');
      }

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        errorBox.classList.add('d-hidden');

        const token = Auth.getToken();
        if (!token) {
          window.location.href = '/login?next=/organiser/create-event';
          return;
        }

        const title = document.getElementById('title').value.trim();
        const date = document.getElementById('date').value;
        const time = document.getElementById('time').value;
        const venueName = document.getElementById('venue').value.trim();
        const lat = parseFloat(document.getElementById('lat').value);
        const lng = parseFloat(document.getElementById('lng').value);
        const capacity = Number(document.getElementById('capacity').value);
        const description = document.getElementById('descriptions').value.trim();
        const category = document.getElementById('type').value;

        if (!title || !date || !time || !venueName || Number.isNaN(lat) || Number.isNaN(lng) || !capacity) {
          showError('Please fill in all required event fields.');
          return;
        }

        const startsAt = `${date}T${time}:00`;
        const response = await fetch('/api/events', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Authorization: `Bearer ${token}`,
          },
          body: JSON.stringify({
            title,
            description,
            category,
            venueName,
            lat,
            lng,
            startsAt,
            capacity,
          }),
        });
        
        const json = await response.json();
        if (!json.success) {
          showError(json.error?.message || 'Could not create event.');
          return;
        }

        window.location.href = '/organiser/events';
      });
    </script>
</body>
</html>
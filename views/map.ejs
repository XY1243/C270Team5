
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title><%= title %> - Map View</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="bg-light text-dark">
  
  <div class="dashboard-container">
    <div class="dashboard-header">
        <h1>📋 <%= title %></h1>
        <div class="user-info">
            <span>Welcome, <strong><%= typeof user !== 'undefined' ? user : 'Organiser' %></strong></span>
            <span class="badge">organiser</span>
            <a href="/" class="logout-btn">Logout</a>
        </div>
    </div>

    <nav class="dashboard-nav bg-white">
        <a href="/organiser/dashboard">Dashboard</a>
        <a href="/organiser/events">My Events</a>
        <a href="/organiser/create-event">Create Event</a>
        <a href="/map" class="active">Map</a>
    </nav>

    <div class="dashboard-content" style="display: flex; flex-direction: column; align-items: center; width: 100%;">
        
        <form class="search-bar" id="searchForm" style="width: 100%; max-width: 700px; border-bottom: none; padding: 0 0 20px 0;">
            <input type="text" id="searchInput" placeholder="Filter events on map by title or venue..." />
            <button type="submit" class="btn">Search</button>
        </form>

        <div class="card" style="width: 100%; max-width: 1000px; padding: 15px; box-sizing: border-box; border-left: none;">
            <div id="map" style="height: 550px; width: 100%; border-radius: 8px; overflow: hidden; z-index: 1;"></div>
        </div>
        
    </div>
  </div>

  <script src="/js/auth.js"></script>
  <script>
    const map = L.map('map').setView([1.3037, 103.8370], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap contributors',
      maxZoom: 19,
    }).addTo(map);
    let markers = [];
    let currentEvents = [];

    function formatDate(iso) {
      return new Date(iso).toLocaleString(undefined, {
        dateStyle: 'medium',
        timeStyle: 'short',
      });
    }

    function clearMarkers() {
      markers.forEach((m) => map.removeLayer(m));
      markers = [];
    }

    function popupHtml(event) {
      // Re-architected to natively leverage your .badge, .logout-btn, and popup classes from styles.css
      return `
        <div class="popup-content" data-event-id="${event.id}">
          <h3 style="margin: 0 0 4px; font-size: 15px; font-weight: 700;">${event.title}</h3>
          <div class="meta" style="font-size: 12px; margin-bottom: 4px;">${event.category || ''} &middot; ${event.venue_name || ''}</div>
          <div class="meta" style="font-size: 12px; margin-bottom: 8px;">${formatDate(event.starts_at)}</div>
          <div class="badge pending" style="display: block; text-align: center; margin-bottom: 8px; padding: 6px; width: 100%; box-sizing: border-box;" data-role="capacity">Checking availability&hellip;</div>
          <div class="actions" style="margin-top: 8px;">
            <button class="logout-btn btn" style="width: 100%; margin-bottom: 6px; border: none; font-size: 12px; text-align: center;" data-role="book" disabled>Book Now</button>
            <a href="/events/${event.id}" class="btn secondary" style="display: block; text-align: center; font-size: 12px; text-decoration: none;">Details</a>
          </div>
        </div>
      `;
    }

    async function checkAvailability(eventId, popupEl) {
      const capacityEl = popupEl.querySelector('[data-role="capacity"]');
      const bookBtn = popupEl.querySelector('[data-role="book"]');
      try {
        const res = await fetch(`/api/events/${eventId}/availability`);
        const json = await res.json();
        if (!json.success) {
          capacityEl.textContent = json.error.message;
          return;
        }
        const { remainingCapacity, capacity } = json.data;
        if (remainingCapacity > 0) {
          capacityEl.textContent = `${remainingCapacity} / ${capacity} spots left`;
          capacityEl.className = 'badge approved';
          capacityEl.style.display = 'block';
          bookBtn.disabled = false;
          bookBtn.style.opacity = '1';
          bookBtn.style.cursor = 'pointer';
        } else {
          capacityEl.textContent = 'Sold out';
          capacityEl.className = 'badge rejected';
          capacityEl.style.display = 'block';
          bookBtn.disabled = true;
          bookBtn.style.opacity = '0.5';
          bookBtn.style.cursor = 'not-allowed';
        }
      } catch (err) {
        capacityEl.textContent = 'Could not check availability';
      }
    }

    async function bookEvent(eventId, popupEl) {
      const token = Auth.getToken();
      if (!token) {
        window.location.href = `/login?next=${encodeURIComponent(window.location.pathname)}`;
        return;
      }
      const ticketCount = Number(prompt('How many tickets?', '1'));
      if (!ticketCount || ticketCount < 1) return;
      const res = await fetch('/api/rsvps', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${token}`,
        },
        body: JSON.stringify({ eventId, ticketCount }),
      });
      const json = await res.json();
      if (json.success) {
        alert('Booking confirmed!');
        checkAvailability(eventId, popupEl);
      } else if (res.status === 401) {
        window.location.href = `/login?next=${encodeURIComponent(window.location.pathname)}`;
      } else {
        alert(json.error.message);
      }
    }

    function addMarker(event) {
      const marker = L.marker([event.lat, event.lng]).addTo(map);
      marker.bindPopup(popupHtml(event));
      marker.on('popupopen', (e) => {
        const popupEl = e.popup.getElement();
        checkAvailability(event.id, popupEl);
        popupEl.querySelector('[data-role="book"]').addEventListener('click', () => {
          bookEvent(event.id, popupEl);
        });
      });
      markers.push(marker);
    }

    function renderEvents(events, query) {
      clearMarkers();
      const q = (query || '').trim().toLowerCase();
      const filtered = q
        ? events.filter(
            (e) =>
              e.title.toLowerCase().includes(q) ||
              (e.venue_name || '').toLowerCase().includes(q)
          )
        : events;
      filtered.forEach(addMarker);
    }

    async function loadEvents() {
      const bounds = map.getBounds();
      const url =
        `/api/map/events?minLat=${bounds.getSouth()}&maxLat=${bounds.getNorth()}` +
        `&minLng=${bounds.getWest()}&maxLng=${bounds.getEast()}`;
      const res = await fetch(url);
      const json = await res.json();
      if (json.success) {
        currentEvents = json.data.events;
        renderEvents(currentEvents, document.getElementById('searchInput').value);
      }
    }

    map.on('moveend', loadEvents);
    document.getElementById('searchForm').addEventListener('submit', (e) => {
      e.preventDefault();
      renderEvents(currentEvents, document.getElementById('searchInput').value);
    });
    map.whenReady(() => {
      map.invalidateSize();
      loadEvents();
    });
  </script>
</body>
</html>
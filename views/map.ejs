<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title><%= title %> - Map View</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="bg-light text-dark">
  
  <%- include('partials/header') %>

  <div class="bg-dark text-white py-2 px-4 shadow-sm d-flex justify-content-between align-items-center border-top border-secondary">
    <h5 class="mb-0 text-white font-monospace fw-bold"><%= title %></h5>
    <div id="authLinks" class="small"></div>
  </div>

  <div class="container mt-4">
    <form class="row g-2 justify-content-center mb-4" id="searchForm">
      <div class="col-md-8 col-sm-10">
        <input type="text" id="searchInput" class="form-control" placeholder="Filter events on map by title or venue..." />
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-primary px-4">Search</button>
      </div>
    </form>

    <div class="card shadow-sm border-0 mb-5">
      <div class="card-body p-0 rounded overflow-hidden">
        <div id="map" style="height: 550px; width: 100%;"></div>
      </div>
    </div>
  </div>

  <script src="/js/auth.js"></script>
  <script>
    Auth.renderTopbarLinks(document.getElementById('authLinks'));
    // App is Singapore-based; center on Singapore so seeded pins are visible on load.
    const map = L.map('map').setView([1.3037, 103.8370], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap contributors',
      maxZoom: 19,
    }).addTo(map);
    let markers = [];
    let currentEvents = [];

    function formatDate(iso) {
      return new Date(iso).toLocaleString(undefined, {
        dateStyle: 'medium',
        timeStyle: 'short',
      });
    }

    function clearMarkers() {
      markers.forEach((m) => map.removeLayer(m));
      markers = [];
    }

    // 1. Corrected popupHtml (Details button only)
    function popupHtml(event) {
      return `
        <div class="popup-container">
          <h5>${event.title}</h5>
          
          <div data-role="capacity" class="badge bg-info p-2 w-100 text-white mb-2">
            Checking availability...
          </div>
          
          <div class="mt-2">
            <a href="/events/${event.id}" class="btn btn-primary btn-sm w-100">Details</a>
          </div>
        </div>
      `;
    }

    // 2. Corrected checkAvailability (No bookBtn logic)
    async function checkAvailability(eventId, popupEl) {
      const capacityEl = popupEl.querySelector('[data-role="capacity"]');

      if (!capacityEl) {
        console.error("Missing data-role attributes in popup HTML!");
        return; 
      }

      try {
        const res = await fetch(`/api/events/${eventId}/availability`);
        const json = await res.json();
        
        if (!json.success) {
          capacityEl.textContent = json.error.message;
          return;
        }
        
        const { remainingCapacity, capacity } = json.data;
        if (remainingCapacity > 0) {
          capacityEl.textContent = `${remainingCapacity} / ${capacity} spots left`;
          capacityEl.className = 'badge bg-success p-2 w-100 text-white';
        } else {
          capacityEl.textContent = 'Sold out';
          capacityEl.className = 'badge bg-danger p-2 w-100 text-white';
        }
      } catch (err) {
        capacityEl.textContent = 'Could not check availability';
      }
    }

    // 3. Corrected addMarker (No addEventListener for booking)
    function addMarker(event) {
      const marker = L.marker([event.lat, event.lng]).addTo(map);
      marker.bindPopup(popupHtml(event));
      marker.on('popupopen', (e) => {
        const popupEl = e.popup.getElement();
        checkAvailability(event.id, popupEl);
      });
      markers.push(marker);
    }

    function renderEvents(events, query) {
      clearMarkers();
      const q = (query || '').trim().toLowerCase();
      const filtered = q
        ? events.filter(
            (e) =>
              e.title.toLowerCase().includes(q) ||
              (e.venue_name || '').toLowerCase().includes(q)
          )
        : events;
      filtered.forEach(addMarker);
    }

    async function loadEvents() {
      const bounds = map.getBounds();
      const url =
        `/api/map/events?minLat=${bounds.getSouth()}&maxLat=${bounds.getNorth()}` +
        `&minLng=${bounds.getWest()}&maxLng=${bounds.getEast()}`;
      const res = await fetch(url);
      const json = await res.json();
      if (json.success) {
        currentEvents = json.data.events;
        renderEvents(currentEvents, document.getElementById('searchInput').value);
      }
    }

    map.on('moveend', loadEvents);
    document.getElementById('searchForm').addEventListener('submit', (e) => {
      e.preventDefault();
      renderEvents(currentEvents, document.getElementById('searchInput').value);
    });
    map.whenReady(() => {
      map.invalidateSize();
      loadEvents();
    });
  </script>
</body>
</html>
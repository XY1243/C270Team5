
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Events Finder - History</title>
</head>

<body>
    <%- include('partials/header') %>
    <div class="container mt-4">
        <h2 class="mb-4">Event Management History</h2>
        
        <% if (history.length == 0) { %>
            <div class="alert alert-info" role="alert">
                📋 No event history found. Get started by creating a new event request!
            </div>

        <% } else { %>
            <table class="table table-striped table-hover align-middle shadow-sm rounded">
                <thead class="table-dark">
                    <tr>
                        <th>Date & Time</th>
                        <th>Event Title</th>
                        <th>Type</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th class="text-center">Edit</th>
                        <th class="text-center">Delete</th>
                    </tr>
                </thead>
                <tbody>
                    <% history.forEach(function(item, index) { %>
                    <tr>
                        <td>
                            <strong><%= item.date %></strong><br>
                            <small class="text-muted"><%= item.time %></small>
                        </td>
                        <td><strong><%= item.name %></strong></td>
                        <td><span class="badge bg-secondary"><%= item.type %></span></td>
                        <td>
                            <small class="text-truncate d-inline-block" style="max-width: 250px;">
                                <%= item.descriptions %>
                            </small>
                        </td>
                        <td>
                            <span class="badge bg-warning text-dark">Pending</span>
                        </td>
                        <td class="text-center">
                            <a href="/edit/<%= index %>" class="btn btn-sm btn-outline-primary">Edit</a>
                        </td>
                        <td class="text-center">
                            <form action="/delete/<%= index %>" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this event submission?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } %>
        <br>
        <a href="/entry" class="btn btn-secondary px-4">Back to Dashboard</a>
    </div>
</body>
</html>